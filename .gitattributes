# Default: normalize all text files and enforce LF
* text=auto eol=lf

# Notebooks
*.ipynb text eol=lf

# Binary files (no line ending normalization)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.zip  binary
*.pkl  binary
*.model binary
*.parquet binary
*.h5 binary
*.onnx binary